# Alexandria Configuration

# Application Settings
APP_NAME=Alexandria
SECRET_KEY=dev-key-change-this-in-production

# Librarian Credentials (Admin)
LIBRARIAN_USERNAME=admin
LIBRARIAN_PASSWORD=alexandria

# Adminer
ADMINER_PASSWORD=secure-password-here

# Google Books API (optional but recommended — avoids shared quota / 429 errors)
# GOOGLE_BOOKS_API_KEY=

# Database
# Use sqlite:///instance/alexandria.db for local or sqlite:////app/instance/alexandria.db for Docker
DATABASE_URL=sqlite:///instance/alexandria.db
